# Generated from cmake/patch_orcaslicer_conf.cmake.in by configure_file().
# Consumed by install(SCRIPT ...); runs at `cmake --install` time.
#
# First-time Orca Slicer configuration: a fresh Orca profile won't
# trust our plugin until four keys are aligned in OrcaSlicer.conf.
# We do that automatically at install time, but only when installing
# to a known Orca config dir (native ~/.config/OrcaSlicer or the
# Flatpak ~/.var/app/com.orcaslicer.OrcaSlicer/config/OrcaSlicer) --
# otherwise the prefix is clearly a staging tree and we should not
# touch the user's live config.
#
# Patch rules (all values are strings in OrcaSlicer.conf -- AppConfig
# stores bools as the literal text "true" / "false"; see
# AppConfig::set(..., bool) in OrcaSlicer's libslic3r/AppConfig.hpp):
#
#   1. app.installed_networking      = "true"
#      Without this Orca won't even try to dlopen the plugin
#      (see GUI_App::on_init_network).
#
#   2. app.network_plugin_version    = "@OBN_VERSION@"
#      File-name version Orca will dlopen
#      (libbambu_networking_<this>.so). Must match the .so we install.
#
#   3. app.network_plugin_remind_later = "true"
#      Suppresses Orca's "a newer plugin is available" banner. The
#      check that gates the banner is should_remind_network_update_later()
#      returning false; we set it true so the user is not pestered to
#      replace our drop-in with the upstream plugin every launch.
#
#   4. Strip @OBN_VERSION@ from app.network_plugin_skipped_versions
#      (a ';'-separated list, see AppConfig::get_skipped_network_versions).
#      If the user previously clicked "Skip this version" for our exact
#      string, Orca would silently refuse to load us.

set(_expected_prefixes "@OBN_CLIENT_EXPECTED_PREFIXES@")
set(_conf_name         "@OBN_CLIENT_CONF_NAME@")
set(_obn_version       "@OBN_VERSION@")

# See patch_bambustudio_conf.cmake.in for the rationale; Orca uses the same
# %APPDATA% layout on Windows.
if(CMAKE_HOST_WIN32)
    set(_user_root "$ENV{APPDATA}")
    set(_user_root_label "APPDATA")
else()
    set(_user_root "$ENV{HOME}")
    set(_user_root_label "HOME")
endif()

if(_user_root STREQUAL "")
    message(STATUS "obn: ${_user_root_label} is not set, skipping ${_conf_name} patch")
else()
    set(_match FALSE)
    foreach(_p IN LISTS _expected_prefixes)
        if(NOT _p STREQUAL "" AND CMAKE_INSTALL_PREFIX STREQUAL _p)
            set(_match TRUE)
            break()
        endif()
    endforeach()
    if(NOT _match)
        message(STATUS
            "obn: install prefix (${CMAKE_INSTALL_PREFIX}) is not a default Orca Slicer config dir; "
            "${_conf_name} is untouched. Edit it by hand if needed: under \"app\" set "
            "\"installed_networking\":\"true\", \"network_plugin_version\":\"${_obn_version}\", "
            "\"network_plugin_remind_later\":\"true\", and remove \"${_obn_version}\" from "
            "\"network_plugin_skipped_versions\".")
    else()
        set(_conf "${CMAKE_INSTALL_PREFIX}/${_conf_name}")
        if(NOT EXISTS "${_conf}")
            message(STATUS
                "obn: ${_conf} does not exist yet -- launch Orca Slicer once "
                "to create it, then re-run 'make install' (or set the "
                "\"installed_networking\" / \"network_plugin_version\" / "
                "\"network_plugin_remind_later\" keys by hand).")
        else()
            file(READ "${_conf}" _orig)
            set(_body "${_orig}")
            string(JSON _app_type ERROR_VARIABLE _err TYPE "${_body}" app)
            if(_err OR NOT _app_type STREQUAL "OBJECT")
                message(WARNING
                    "obn: ${_conf} has no top-level \"app\" object; "
                    "skipping patch. Error: ${_err}")
            else()
                string(JSON _body SET "${_body}" app installed_networking      "\"true\"")
                string(JSON _body SET "${_body}" app network_plugin_version    "\"${_obn_version}\"")
                string(JSON _body SET "${_body}" app network_plugin_remind_later "\"true\"")
                # Mirror the Bambu Studio patch: only Windows / macOS perform
                # signature validation, so only those platforms need the
                # ignore_module_cert override. On Linux the key is harmless
                # but useless; skip it to keep the .conf clean.
                if(CMAKE_HOST_WIN32 OR CMAKE_HOST_APPLE)
                    string(JSON _body SET "${_body}" app ignore_module_cert "\"1\"")
                endif()

                # Strip OBN_VERSION from network_plugin_skipped_versions if
                # present. The key may be missing entirely -- ERROR_VARIABLE
                # makes the absence silent rather than a CMake error. Orca
                # stores the value as a literal ';'-separated CMake-style
                # list inside a JSON string, so foreach(IN LISTS) splits on
                # ';' for free and list(JOIN) re-joins with the same
                # separator.
                string(JSON _skipped ERROR_VARIABLE _skipped_err GET "${_body}"
                    app network_plugin_skipped_versions)
                if(NOT _skipped_err AND NOT _skipped STREQUAL "")
                    set(_kept_list "")
                    foreach(_token IN LISTS _skipped)
                        if(NOT _token STREQUAL "" AND NOT _token STREQUAL _obn_version)
                            list(APPEND _kept_list "${_token}")
                        endif()
                    endforeach()
                    list(JOIN _kept_list ";" _kept_orca)
                    if(NOT _kept_orca STREQUAL _skipped)
                        # JSON string value: quote it; ';' needs no JSON
                        # escaping.
                        string(JSON _body SET "${_body}" app network_plugin_skipped_versions
                            "\"${_kept_orca}\"")
                    endif()
                endif()

                # Strip the trailing "# MD5 checksum <hex>" line from the
                # original before comparison: string(JSON SET) returns the
                # JSON object without trailing comments, so a verbatim
                # _body vs _orig compare would always say "changed" even
                # for a no-op patch and rewrite the file (invalidating
                # the MD5 the user already has on disk).
                string(REGEX REPLACE "[\r\n]+# MD5 checksum[^\r\n]*[\r\n]*$" ""
                    _orig_json "${_orig}")

                if(NOT _body STREQUAL _orig_json)
                    file(WRITE "${_conf}.obn-bak" "${_orig}")
                    # Orca Slicer (forked from PrusaSlicer/AppConfig) does
                    # the same trailing "# MD5 checksum <32 hex>" trick
                    # Bambu Studio inherits, and crashes with
                    # std::out_of_range during AppConfig::load when the
                    # line is missing. Append a placeholder in Studio's
                    # exact format so the load path is happy; Orca will
                    # rewrite the hash with the real one on its next
                    # clean save.
                    file(WRITE "${_conf}"
                        "${_body}\n# MD5 checksum 00000000000000000000000000000000\n")
                    message(STATUS
                        "obn: patched ${_conf} (backup saved to ${_conf}.obn-bak)")
                    if(EXISTS "${_conf}.bak")
                        message(STATUS
                            "obn: an Orca-managed ${_conf}.bak is present; "
                            "Orca will refresh it on next clean save. "
                            "If Orca still refuses to start, remove that .bak "
                            "manually so it cannot fall back to the pre-patch copy.")
                    endif()
                else()
                    message(STATUS
                        "obn: ${_conf} already has installed_networking=true, "
                        "network_plugin_version=${_obn_version}, "
                        "network_plugin_remind_later=true, "
                        "and ${_obn_version} is not in network_plugin_skipped_versions")
                endif()
            endif()
        endif()
    endif()
endif()
