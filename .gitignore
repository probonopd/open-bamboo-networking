build/
build-*/
build.stale-*/
config.mk
config.ps1
.cache/
.vcpkg/
# vcpkg manifest-mode install tree: regenerated from vcpkg.json on every
# fresh configure, can easily reach gigabytes (downloaded sources, debug
# libs, etc.). Nothing in the repo should reference it directly.
vcpkg_installed/
compile_commands.json
*.o
*.so
*.dylib
*.dll
*.a
.vscode/
.idea/
patches/
3rd_party/

# Diagnostic captures we keep producing while debugging Studio:
# session logs from BambuStudio.conf log dir, exported symbol tables
# from the stock plugin, ad-hoc cmake/build transcripts, etc. They
# are useful locally but nothing in the repo references them.
*.log
*.log.0
*.log.0.log
obn-session.log*
obn_session_log_*.txt
exports_*.txt
cmake_bambu_out.txt
debug_*.log.*
